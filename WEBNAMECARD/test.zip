 <!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>My Web Card</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;500;700&display=swap" rel="stylesheet">

<style>
body{
    margin:0;
    font-family:'Poppins', sans-serif;
}

/* 기본 배경 */
.overlay{
    position:fixed;
    width:100%;
    height:100vh;
    background:rgba(0,0,0,0.5);
    display:flex;
    justify-content:center;
    align-items:center;
    transition:0.3s;
}

/* 카드 */
.card{
    background:#f2f2f2;
    width:420px;
    padding:50px 40px;
    border-radius:20px;
    text-align:center;
    box-shadow:0 20px 50px rgba(0,0,0,0.25);
    position:relative;
    transition:0.3s;
}

/* 닫기 버튼 */
.close{
    position:absolute;
    top:15px;
    right:15px;
    background:#999;
    color:white;
    width:28px;
    height:28px;
    border-radius:50%;
    line-height:28px;
    cursor:pointer;
    font-size:14px;
}

img{
    width:130px;
    height:130px;
    border-radius:50%;
    object-fit:cover;
}

h1{
    margin:20px 0 5px;
}

.title{
    color:gray;
    margin-bottom:15px;
}

.email{
    margin:10px 0;
    font-size:14px;
}

button{
    margin-top:15px;
    padding:10px 20px;
    border:none;
    background:#2d6cdf;
    color:white;
    border-radius:6px;
    cursor:pointer;
    font-size:14px;
}

.links{
    margin-top:15px;
}

.links a{
    margin:0 10px;
    text-decoration:none;
    color:#2d6cdf;
    font-size:14px;
}

/* ===== 다크모드 ===== */
.dark-overlay{
    background:rgba(0,0,0,0.9);
}

.dark-card{
    background:#1e1e1e;
    color:white;
}

.dark-card .title{
    color:#ccc;
}

.dark-card .links a{
    color:#6ea8ff;
}
</style>
</head>

<body>

<div class="overlay">
  <div class="card">

    <div class="close">X</div>

    <img src="profile.jpg" alt="profile">

    <h1>이영인</h1>
    <div class="title">English Lecturer</div>

    <div class="email">
      pollyortaki@gmail.com
    </div>

    <button onclick="copyEmail()">이메일 복사</button>

    <div class="links">
      <a href="#">GitHub</a>
      <a href="#">LinkedIn</a>
    </div>

    <button onclick="toggleDarkMode()">다크모드 전환</button>

  </div>
</div>

<script>
function copyEmail(){
    navigator.clipboard.writeText("pollyortaki@gmail.com");
    alert("이메일이 복사되었습니다.");
}

function toggleDarkMode(){
    document.querySelector(".overlay").classList.toggle("dark-overlay");
    document.querySelector(".card").classList.toggle("dark-card");
}
</script>

</body>
</html>